# Supabase (Project Settings → API). Same values as the desktop app's .env.
# The publishable key is a public browser key — safe to ship; data is protected by RLS.
# In Vercel, set these as Environment Variables (Root Directory = mobile/).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
